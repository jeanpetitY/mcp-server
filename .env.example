# MCP Server name
MCP_SERVER_NAME="tib-mcp"

# MCP Server Transport: "stdio" | "http" | "sse" | "streamable-http"
MCP_TRANSPORT=streamable-http

# Host and port (only used for http/sse/streamable-http transports)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
MCP_LOG_LEVEL=INFO

# OpenAI key used by the LangChain client (client_langchain.py)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0

# LangChain MCP client settings
# Transport: "stdio" | "sse" | "streamable-http"
MCP_CLIENT_TRANSPORT=streamable-http
MCP_CLIENT_URL=http://127.0.0.1:8000/mcp

# Used only when MCP_CLIENT_TRANSPORT=stdio
MCP_CLIENT_COMMAND=uv
MCP_CLIENT_CWD=
