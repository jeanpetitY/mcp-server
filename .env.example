# MCP Server name
MCP_SERVER_NAME="tib-mcp"

# MCP Server Transport: "stdio" | "http" | "sse" | "streamable-http"
MCP_TRANSPORT=streamable-http

# Host and port (only used for http/sse/streamable-http transports)
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
MCP_LOG_LEVEL=INFO
